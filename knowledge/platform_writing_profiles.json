  "profiles": {
    "fanqie": {
      "name": "番茄小说",
      "core_logic": "算法推荐+拉新向",
      "key_metric": "完读率、追读率、前三章留存",
      "chapter_length": "1500±50字",
      "opening": {
        "hook_position": "前300字必须出冲突",
        "golden_rule": "黄金三章已死，黄金三钩当立。七行内抛出首个钩子，300字内决定追不追",
        "first_chapter_structure": {
          "0-10%": "异常事件触发（死亡/背叛/系统绑定/规则突变）",
          "10-40%": "主角反应+初步行动",
          "40-80%": "小高潮或致命悬念",
          "80-100%": "强钩子收尾"
        }
      },
      "paragraph_rules": {
        "max_lines_per_para": 3,
        "dialogue_format": "对话必须独立成行",
        "forbidden": ["长段落", "大段心理描写", "大段环境描写", "总结性的话", "回忆倒叙"]
      },
      "sentence_rules": {
        "max_chars_per_sentence": 15,
        "style": "短句为主，大白话，拒绝文艺修辞、生僻字",
        "forbidden_patterns": ["长难句", "生僻词", "书面化连接词（因此/此外/综上所述）"]
      },
      "dialogue_rules": {
        "min_ratio": 0.4,
        "style": "信息密度高，每句推进一个信息点或情绪点",
        "forbidden": ["文言文", "书面语对话", "过度礼貌"]
      },
      "scene_rules": {
        "min_scenes_per_chapter": 3,
        "max_scenes_per_chapter": 5,
        "transition_style": "硬切，禁止过渡描写"
      },
      "emotion_delivery": {
        "style": "直给型",
        "forbidden": ["延迟满足", "过度留白", "克制含蓄"],
        "required": "每500字1个小爽点，每章1次打脸/逆袭"
      },
      "satisfaction_points": {
        "small": "每3章至少1个",
        "medium": "每10章至少1个",
        "large": "每20章至少1个"
      },
      "character_rules": {
        "protagonist": "杀伐果断，有仇必报，不圣母、不优柔寡断",
        "antagonist": "脸谱化，前期嚣张跋扈，被快速碾压",
        "max_chars_first_chapter": 2
      },
      "taboo": ["洗白反派", "主角降智", "圣母心", "狗血误会", "憋屈内耗", "大团圆结局"],
      "ai_trace_high_risk": ["冰冷的眼神", "嘴角勾起", "冷哼一声", "瞳孔骤缩", "倒吸一口凉气", "脸色大变"]
    },
