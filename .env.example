# 盘古AI写作系统配置文件
# 复制此文件为 .env 并填入你的配置

# DeepSeek API密钥
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-d0a65c094b53413d8712e93c364ebeea

# OpenAI兼容API的Base URL（可选）
OPENAI_BASE_URL=https://api.deepseek.com/v1

# AI模型配置
# DeepSeek 模型列表（最新V4系列）:
# - deepseek-v4-flash (默认，速度快，适合写小说/日常任务)
# - deepseek-v4-pro (性能强，适合复杂任务)
# - deepseek-chat (旧版，即将停止支持)
# - deepseek-reasoner (旧版推理模型，即将停止支持)
# - deepseek-coder (代码生成)
AI_MODEL=deepseek-v4-flash

# 生成参数
TEMPERATURE=0.7
MAX_TOKENS=4000
TIMEOUT=120
RETRY_TIMES=3
