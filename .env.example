# 盘古AI写作系统配置文件
# 复制此文件为 .env 并填入你的配置

# ============ DeepSeek / OpenAI-compatible ============
# DeepSeek API密钥
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-key-here

# OpenAI兼容API的Base URL（可选）
OPENAI_BASE_URL=https://api.deepseek.com/v1

# DeepSeek 模型列表（最新V4系列）:
# - deepseek-v4-flash (速度快，适合批量生成)
# - deepseek-v4-pro (性能强，适合复杂任务)
# - deepseek-chat
# - deepseek-reasoner
AI_MODEL=deepseek-chat

# ============ Anthropic (Claude) ============
# Anthropic API密钥
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude 模型:
# - claude-sonnet-4-6-20250514 (推荐，质量/速度/价格最佳平衡)
# - claude-opus-4-8-20250514 (最强，适合关键创意节点)
# - claude-haiku-4-5-20251001 (最快，适合批量轻量任务)
ANTHROPIC_MODEL=claude-sonnet-4-6-20250514

# Anthropic API 地址（无需修改，除非使用代理）
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_TIMEOUT=180
ANTHROPIC_RETRIES=3

# ============ Stage→模型路由（可选）============
# JSON格式，key=stage_id, value=model
# 推荐配置: W2用DeepSeek打骨架，W4用Claude做精装
# PANGU_STAGE_MODELS={"W2":"deepseek-chat","W4":"claude-sonnet-4-6-20250514"}
PANGU_STAGE_MODELS=

# ============ 生成参数 ============
TEMPERATURE=0.7
MAX_TOKENS=8192
TIMEOUT=180
RETRY_TIMES=3
